   "source": [
    "import seaborn as sns\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "tips = sns.load_dataset(\"tips\")\n",
    "\n",
    "sns.boxplot(\n",
    "    data=tips,\n",
    "    x=\"day\",\n",
    "    y=\"total_bill\",\n",
    "    hue=\"sex\"\n",
    ")\n",
    "\n",
    "plt.title(\"Total Bill by Day and Sex\")\n",
    "plt.show()"
   ]
