import seaborn as sns;
import matplotlib.pyplot as plt; 



sns.set_theme(); # first work 


sns.get_dataset_names(); # all data in seaborn 


tips = sns.load_dataset("tips");
print(type(tips));
print(tips.head())


sns.relplot(
    data=tips,
    x="total_bill",
    y="tip",
    hue="smoker", # ye alag se highlight kar dega smokers ko in color 
    size="size",
    style="smoker" # ye smkers ke style  ko badal dega
);


 # line plot 
sns.relplot(
    data=tips,
    x="total_bill",
    y="tip",
    kind="line",
    hue="smoker", # ye alag se highlight kar dega smokers ko in color 
    size="size",
    style="smoker" # ye smkers ke style  ko badal dega
);


# relational plots -------------> scatter and line plots 
tips = sns.load_dataset("tips");

sns.scatterplot(
    data=tips,
    x="total_bill",
    y="tip",
    hue="time"
)


#line plots 
flights = sns.load_dataset("flights");
flights.head();
sns.lineplot(
    data=flights,
    x="year",
    y="passengers"
);


#bar plot 
tips.head()
sns.barplot(
    data=tips,
    x="day",
    y="tip",
    hue="sex" 
)


#box plot 
sns.boxplot(
     data=tips,
    x="day",
    y="tip",
)


# histograms 

penguins = sns.load_dataset("penguins");
sns.histplot(
    data=penguins,
    x="body_mass_g",
    bins=30
    
)


#heat map 
flight_pivot=flights.pivot(index="month",columns="year",values="passengers");
print(flight_pivot);
sns.heatmap(
    data=flight_pivot,
    cmap="coolwarm",
    annot=True,
    fmt="d"
    
)


#modern seaborn 
fig,ax = plt.subplots()
sns.lineplot(
    data=sns.load_dataset("tips"),
    x="day",
    y="total_bill",
    hue="sex",
    ax=ax,
    marker="o",
    errorbar=None # ci ko hide krne ke liye
)
ax.set_title("BoxPlot: total bill by sex");
ax.set_xlabel("Day of the week");
ax.set_ylabel("Total Bill ($)");
plt.legend(title="sex");

plt.show()


#modern seaborn 
fig,ax = plt.subplots()
sns.boxplot(
    data=sns.load_dataset("tips"),
    x="day",
    y="total_bill",
    hue="sex",
    ax=ax,
    marker="o",
    errorbar=None # ci ko hide krne ke liye
)
ax.set_title("BoxPlot: total bill by sex");
ax.set_xlabel("Day of the week");
ax.set_ylabel("Total Bill ($)");
plt.legend(title="sex");

plt.show()



