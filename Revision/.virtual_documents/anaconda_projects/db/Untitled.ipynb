import matplotlib.pyplot as plt 


# line plot 
years = [2010, 2011, 2012, 2013, 2014, 2015, 2016, 2017, 2018, 2019, 2020, 2021, 2022, 2023]
co2_emissions = [33.1, 34.3, 34.9, 35.3, 35.5, 35.4, 35.4, 36.2, 36.7, 36.7, 34.8, 36.3, 37.1, 37.4]

#------------------------------------------------------------------------------------------------------
plt.plot(years,co2_emissions,"<-g",label="co2 emissions throghout years",)
plt.legend()
plt.xlabel("Years")
plt.ylabel("co2_Emissions")
plt.grid(True)
plt.style.use("ggplot")
plt.tight_layout()
plt.show()


with plt.xkcd():
    plt.plot(years, co2_emissions, "g<-", label="CO2 Emissions")
    plt.xlabel("Years")
    plt.ylabel("CO2 Emissions")
    plt.legend()
    plt.grid(True)
    plt.tight_layout()
    plt.show()


